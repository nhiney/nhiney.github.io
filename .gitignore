node_modules/
.DS_Store

# Reference / scratch — never commit
saasfly-main/

# Local tooling / agent scratch state — keep on the machine, never push
.agent_context/
.agents/
.multica/
.iworkflow/
.claude/

# personal writing-voice guide & local notes — local only, never push
docs/
tasks/
task.md

# Thesis / khóa luận — CONFIDENTIAL source scans, local only, never push
paper/

# Next.js build output (root) — deployed via gh-pages branch, never committed to main
_next/
_not-found/
out/
404/
blog/
projects/
index.html
index.txt
404.html
robots.txt
sitemap.xml
favicon.ico
*.txt
*.svg

# Re-include portfolio source (the *.txt / *.svg rules above would otherwise hide it)
!portfolio/**
!README.md

# Single package manager = bun. Block stray npm / pnpm / yarn lockfiles anywhere
# (after !portfolio/** so the rule also applies inside portfolio/).
package-lock.json
pnpm-lock.yaml
yarn.lock

# Local environment variables — keep real analytics keys out of git.
.env
.env.*
portfolio/.env
portfolio/.env.*
!portfolio/.env.example

# Build-generated assets — recreated by the prebuild scripts (generate-og.mjs,
# generate-tree.mjs) on every build/deploy, so they never belong in git.
# After !portfolio/** so "last matching rule wins" keeps them excluded.
portfolio/public/og/
portfolio/public/mind-map/tree-*.webp

# Private thesis deck — MUST stay ignored even after the portfolio re-include above.
# Placed LAST so "last matching rule wins" keeps it excluded (confidential client data).
portfolio/app/nguyenthiyennhi-klcn-ai-logistics-doc-extractor/
portfolio/app/nguyenthiyennhi-klcn-ai-logistics-doc-extractor/**
